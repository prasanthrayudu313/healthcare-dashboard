# ─── Database ───────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DATABASE_URL="file:./healthcare.db"

# ─── AI Summarization (FREE — sign up at https://console.groq.com) ──────────
# Groq is free for personal use. Create an account and get your API key.
# Without this key, the dashboard still works but shows rule-based summaries instead of AI.
GROQ_API_KEY=your_groq_api_key_here

# ─── App Config ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Centene Intelligence Hub"
NEXT_PUBLIC_REFRESH_INTERVAL_MS=300000

# ─── PubMed API (optional, increases rate limit from 3/sec to 10/sec) ───────
# Get free key at https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# ─── FDA OpenFDA (optional, increases rate limit from 240/min to 1000/min) ──
# Get free key at https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=
